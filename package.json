{
  "name": "rich-markdown-editor",
  "displayName": "Rich Markdown Editor",
  "description": "Preview and edit Markdown files inline with a rich WYSIWYG editor (Toast UI) including toolbar, tables, and image attachments.",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanbazhagan/rich-md-editor.git"
  },
  "bugs": {
    "url": "https://github.com/tanbazhagan/rich-md-editor/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Visualization", "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "richMarkdownEditor.open",
        "title": "Rich Markdown Editor",
        "category": "Markdown"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "command": "richMarkdownEditor.open",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "command": "richMarkdownEditor.open",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "richMarkdownEditor.open",
          "when": "resourceExtname == .md || resourceExtname == .markdown"
        }
      ]
    },
    "keybindings": [
      {
        "command": "richMarkdownEditor.open",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname == .md || resourceExtname == .markdown"
      }
    ],
    "customEditors": [
      {
        "viewType": "richMarkdownEditor.editor",
        "displayName": "Rich Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "esbuild build/editor-entry.js --bundle --minify --format=iife --outfile=media/toastui-editor.js --platform=browser",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.28.0",
    "ovsx": "^0.9.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "prismjs": "^1.30.0"
  }
}
